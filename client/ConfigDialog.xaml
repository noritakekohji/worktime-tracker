<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="初回設定 - WorkTime Tracker"
    Height="620" Width="620"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    Background="#f6faf8"
    FontFamily="Meiryo UI, Yu Gothic UI, Segoe UI"
    FontSize="13"
    TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <SolidColorBrush x:Key="Surface" Color="#ffffff"/>
        <SolidColorBrush x:Key="Border"  Color="#cdebd6"/>
        <SolidColorBrush x:Key="Text"    Color="#1f2937"/>
        <SolidColorBrush x:Key="Muted"   Color="#6b7280"/>
        <SolidColorBrush x:Key="Emerald" Color="#10b981"/>
        <SolidColorBrush x:Key="EmeraldD" Color="#059669"/>
        <SolidColorBrush x:Key="Soft"    Color="#d1fae5"/>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Text}"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Text}"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource Surface}"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Background" Value="#ecfdf5"/>
            <Setter Property="Foreground" Value="{StaticResource EmeraldD}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#d1fae5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Primary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Emerald}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="{StaticResource Emerald}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource EmeraldD}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="20">
        <TextBlock DockPanel.Dock="Top" Text="接続設定" FontSize="18" FontWeight="Bold" Foreground="{StaticResource EmeraldD}" Margin="0,0,0,16"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="TestBtn"   Content="🔌 接続テスト"/>
            <Button x:Name="CancelBtn" Content="キャンセル"/>
            <Button x:Name="SaveBtn"   Content="✓ 保存して開始" Style="{StaticResource Primary}" MinWidth="160"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="保存先モード:"/>
            <ComboBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" x:Name="ModeCombo">
                <ComboBoxItem Content="gitlab" IsSelected="True"/>
                <ComboBoxItem Content="github"/>
                <ComboBoxItem Content="local"/>
            </ComboBox>
            <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" FontSize="11"
                       Text="gitlab/github: REST API 経由で保管 / local: 指定フォルダ (共有ドライブ等) に保管"/>

            <Label Grid.Row="2" Grid.Column="0" x:Name="UrlLabel" Content="GitLab URL:"/>
            <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" x:Name="UrlBox"/>

            <Label Grid.Row="3" Grid.Column="0" x:Name="ProjectIdLabel" Content="Project ID / Path:"/>
            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" x:Name="ProjectIdBox"/>
            <TextBlock Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" x:Name="ProjectIdHint" FontSize="11"
                       Text='数値 ID (例: 12345) または "group/subgroup/project"'/>

            <Label Grid.Row="5" Grid.Column="0" x:Name="BranchLabel" Content="ブランチ:"/>
            <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" x:Name="BranchBox" Text="main"/>

            <Label Grid.Row="6" Grid.Column="0" x:Name="TokenLabel" Content="Access Token:"/>
            <PasswordBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" x:Name="TokenBox"/>
            <TextBlock Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" x:Name="TokenHint" FontSize="11"
                       Text="GitLab Project Access Token (DPAPI 暗号化で保管)"/>

            <Label Grid.Row="8" Grid.Column="0" x:Name="LocalRootLabel" Content="データフォルダ:" Visibility="Collapsed"/>
            <TextBox Grid.Row="8" Grid.Column="1" x:Name="LocalRootBox" Visibility="Collapsed"/>
            <Button  Grid.Row="8" Grid.Column="2" x:Name="BrowseBtn" Content="📁 参照…" Visibility="Collapsed"/>
            <TextBlock Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" x:Name="LocalRootHint" FontSize="11"
                       Text="master/ と data/ サブフォルダがこの下に作成されます (共有ドライブ可)"
                       Visibility="Collapsed"/>

            <Label Grid.Row="10" Grid.Column="0" Content="あなたの Member ID:"/>
            <TextBox Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="2" x:Name="MemberIdBox"/>
            <TextBlock Grid.Row="11" Grid.Column="1" Grid.ColumnSpan="2" FontSize="11"
                       Text="master/members.json に登録されている ID (空欄なら Windows ログイン名で補完)"/>

            <TextBlock Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="3" x:Name="StatusText" FontSize="12" Margin="0,14,0,0" TextWrapping="Wrap"/>
        </Grid>
    </DockPanel>
</Window>
