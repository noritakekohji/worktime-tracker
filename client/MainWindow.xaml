<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WorkTime Tracker"
    Height="720" Width="1100"
    WindowStartupLocation="CenterScreen"
    Background="#1e1e2e">
    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="MinHeight" Value="26"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="MinHeight" Value="26"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="2"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="#a6e3a1"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- 上部: 作業者・表示月 -->
        <Border DockPanel.Dock="Top" Background="#11111b" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Label Content="作業者:" />
                <ComboBox x:Name="MemberCombo" Width="200" DisplayMemberPath="display" SelectedValuePath="id"/>
                <Label Content="表示年月:" Margin="20,0,0,0"/>
                <ComboBox x:Name="YearCombo" Width="80" />
                <ComboBox x:Name="MonthCombo" Width="60" />
                <Button x:Name="ReloadBtn" Content="再読込 (git pull)" />
                <TextBlock x:Name="StatusText" Text="" Margin="20,0,0,0" Foreground="#f9e2af"/>
            </StackPanel>
        </Border>

        <!-- 下部: 保存 -->
        <Border DockPanel.Dock="Bottom" Background="#11111b" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="HoursTotalText" Text="月合計: 0.0 h" Margin="0,0,20,0" FontWeight="Bold"/>
                <Button x:Name="SaveBtn" Content="保存して push" Background="#a6e3a1" Foreground="#11111b" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左: 新規エントリ入力フォーム -->
            <GroupBox Grid.Column="0" Header="新規エントリ">
                <Grid Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="日付 (バックデートOK):"/>
                    <DatePicker Grid.Row="0" Grid.Column="1" x:Name="EntryDate"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="プロジェクト:"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="ProjectCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="工程:"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="ProcessCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="タスクグループ:"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="TaskGroupCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="タスク:"/>
                    <ComboBox Grid.Row="4" Grid.Column="1" x:Name="TaskCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                    <Label Grid.Row="5" Grid.Column="0" Content="カテゴリ:"/>
                    <ComboBox Grid.Row="5" Grid.Column="1" x:Name="CategoryCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                    <Label Grid.Row="6" Grid.Column="0" Content="工数 (時間):"/>
                    <TextBox Grid.Row="6" Grid.Column="1" x:Name="HoursBox" Text="1.0"/>

                    <Label Grid.Row="7" Grid.Column="0" Content="コメント:"/>
                    <TextBox Grid.Row="7" Grid.Column="1" x:Name="CommentBox" Height="60" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                    <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="ClearBtn" Content="クリア"/>
                        <Button x:Name="AddBtn" Content="追加" Background="#89b4fa" Foreground="#11111b" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- 右: 当月エントリ一覧 -->
            <GroupBox Grid.Column="1" Header="当月エントリ一覧">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="DeleteRowBtn" Content="選択行を削除"/>
                    </StackPanel>
                    <DataGrid x:Name="EntriesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              Background="#181825"
                              Foreground="#cdd6f4"
                              RowBackground="#1e1e2e"
                              AlternatingRowBackground="#181825"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#313244">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="日付" Binding="{Binding date}" Width="90"/>
                            <DataGridTextColumn Header="プロジェクト" Binding="{Binding project_code}" Width="100"/>
                            <DataGridTextColumn Header="工程" Binding="{Binding process_code}" Width="80"/>
                            <DataGridTextColumn Header="ﾀｽｸｸﾞﾙｰﾌﾟ" Binding="{Binding task_group_code}" Width="90"/>
                            <DataGridTextColumn Header="タスク" Binding="{Binding task_code}" Width="90"/>
                            <DataGridTextColumn Header="カテゴリ" Binding="{Binding category}" Width="80"/>
                            <DataGridTextColumn Header="工数" Binding="{Binding hours}" Width="60"/>
                            <DataGridTextColumn Header="コメント" Binding="{Binding comment}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
