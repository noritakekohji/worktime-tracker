<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WorkTime Tracker"
    Height="780" Width="1280"
    WindowStartupLocation="CenterScreen"
    Background="#064e3b"
    FontFamily="Meiryo UI, Yu Gothic UI, Segoe UI"
    FontSize="13"
    TextOptions.TextFormattingMode="Display"
    TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <!-- カラーパレット: エメラルドグリーン × オフホワイト (柔らかいパステル) -->
        <SolidColorBrush x:Key="Bg"        Color="#f6faf8"/>
        <SolidColorBrush x:Key="Surface"   Color="#ffffff"/>
        <SolidColorBrush x:Key="Surface2"  Color="#ecfdf5"/>
        <SolidColorBrush x:Key="Border"    Color="#cdebd6"/>
        <SolidColorBrush x:Key="Text"      Color="#1f2937"/>
        <SolidColorBrush x:Key="TextMuted" Color="#6b7280"/>
        <SolidColorBrush x:Key="Emerald"   Color="#10b981"/>
        <SolidColorBrush x:Key="EmeraldD"  Color="#059669"/>
        <SolidColorBrush x:Key="EmeraldL"  Color="#a7f3d0"/>
        <SolidColorBrush x:Key="Soft"      Color="#d1fae5"/>
        <SolidColorBrush x:Key="Sky"       Color="#7dd3fc"/>
        <SolidColorBrush x:Key="Amber"     Color="#fbbf24"/>
        <SolidColorBrush x:Key="Rose"      Color="#fb7185"/>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Padding" Value="8,2"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Text}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="MinHeight" Value="26"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource Surface}"/>
        </Style>

        <!-- 標準ボタン (薄いミント) -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Background" Value="{StaticResource Surface2}"/>
            <Setter Property="Foreground" Value="{StaticResource EmeraldD}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#d1fae5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#a7f3d0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="#f3f4f6"/>
                                <Setter Property="Foreground" Value="#9ca3af"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- アクセントボタン: メインアクション (エメラルド塗りつぶし) -->
        <Style x:Key="Primary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Emerald}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="{StaticResource Emerald}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource EmeraldD}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#047857"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- セカンダリ (薄塗り) -->
        <Style x:Key="Secondary" TargetType="Button" BasedOn="{StaticResource Primary}">
            <Setter Property="Background" Value="{StaticResource EmeraldL}"/>
            <Setter Property="Foreground" Value="{StaticResource EmeraldD}"/>
        </Style>
        <!-- 警告 (やわらかい琥珀) -->
        <Style x:Key="Warning" TargetType="Button" BasedOn="{StaticResource Primary}">
            <Setter Property="Background" Value="{StaticResource Amber}"/>
            <Setter Property="Foreground" Value="#7c2d12"/>
        </Style>
        <!-- 危険 (やわらかいローズ) -->
        <Style x:Key="Danger" TargetType="Button" BasedOn="{StaticResource Primary}">
            <Setter Property="Background" Value="{StaticResource Rose}"/>
        </Style>

        <!-- クイック数値ボタン -->
        <Style x:Key="QuickHour" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="42"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- カードコンテナ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource EmeraldD}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ===== ヘッダ (濃色) ===== -->
        <Border DockPanel.Dock="Top" Background="#064e3b" Padding="18,14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="AdminBtn" Content="🛠 管理者モード" Visibility="Collapsed" Background="#0f766e" Foreground="White" BorderBrush="#0f766e"/>
                    <Button x:Name="UserPrefsBtn" Content="⭐ 個人設定" Background="#0f766e" Foreground="White" BorderBrush="#0f766e"/>
                    <Button x:Name="SettingsBtn" Content="⚙ 設定" Background="#0f766e" Foreground="White" BorderBrush="#0f766e"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="📅 表示" Foreground="#a7f3d0" Margin="0,0,8,0"/>
                    <ComboBox x:Name="YearCombo" Width="84"/>
                    <TextBlock Text="/" Margin="4,0" Foreground="#a7f3d0"/>
                    <ComboBox x:Name="MonthCombo" Width="64"/>
                    <Button x:Name="ReloadBtn" Content="📋 読込" Margin="8,0,0,0" Background="#0f766e" Foreground="White" BorderBrush="#0f766e"
                            ToolTip="ローカルから当月データを再読込"/>
                    <Button x:Name="PullBtn" Content="📥 取得" Margin="4,0,0,0" Background="#0369a1" Foreground="White" BorderBrush="#0369a1"
                            ToolTip="Gitlab からマスタ + 当月個人実績を取得 → ローカルから読込"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#ecfdf5" CornerRadius="20" Padding="14,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock x:Name="CurrentMemberText" Text="" FontWeight="Bold" FontSize="14" Foreground="{StaticResource EmeraldD}"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="StatusText" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="#fde68a"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== フッタ (濃色) ===== -->
        <Border DockPanel.Dock="Bottom" Background="#064e3b" Padding="18,14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" x:Name="ModeText" Foreground="#a7f3d0" FontSize="11" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Left" x:Name="VersionText" Margin="12,0,0,0" Foreground="#6ee7b7" FontSize="11" VerticalAlignment="Center"
                           Cursor="Hand" TextDecorations="Underline"
                           ToolTip="クリックで変更履歴 (CHANGELOG) を表示"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="#0f766e" CornerRadius="8" Padding="12,6" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📅 選択日" Foreground="#a7f3d0" Margin="0,0,8,0" FontWeight="Bold"/>
                            <TextBlock x:Name="HoursDayText" Text="0.0 h" FontWeight="Bold" FontSize="15" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0f766e" CornerRadius="8" Padding="12,6" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏱ 月合計" Foreground="#a7f3d0" Margin="0,0,8,0" FontWeight="Bold"/>
                            <TextBlock x:Name="HoursTotalText" Text="0.0 h" FontWeight="Bold" FontSize="16" Foreground="White"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="SaveBtn" Content="💾 保存" Style="{StaticResource Primary}" MinWidth="100"/>
                    <Button x:Name="PushBtn" Content="📤 送信" Style="{StaticResource Primary}" MinWidth="100" Margin="6,3,3,3"/>
                    <Button x:Name="OpenFolderBtn" Content="📂 開く" Margin="6,3,3,3" Background="#0f766e" Foreground="White" BorderBrush="#0f766e"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== 本体 (左: 当月実績 / 右: 入力フォーム) ===== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="440"/>
            </Grid.ColumnDefinitions>

            <!-- 左: 当月一覧 -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ListTitle" Text="📋 当月エントリ一覧" Style="{StaticResource SectionTitle}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="DuplicateBtn" Content="⎘ 行を複製"/>
                            <Button x:Name="EditRowBtn" Content="✎ 編集"/>
                            <Button x:Name="DeleteRowBtn" Content="🗑 削除" Style="{StaticResource Danger}"/>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid x:Name="EntriesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              Background="{StaticResource Surface}"
                              Foreground="{StaticResource Text}"
                              RowBackground="{StaticResource Surface}"
                              AlternatingRowBackground="#f0fdf4"
                              GridLinesVisibility="None"
                              BorderBrush="{StaticResource Border}"
                              BorderThickness="1"
                              FontSize="13"
                              RowHeight="34"
                              ColumnHeaderHeight="38">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource Soft}"/>
                                <Setter Property="Foreground" Value="{StaticResource EmeraldD}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,4"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="10,4"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource EmeraldL}"/>
                                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <!-- 未保存行 (dirty='yes') は薄黄色背景 + 左に橙ボーダー -->
                            <Style TargetType="DataGridRow">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding dirty}" Value="yes">
                                        <Setter Property="Background" Value="#fff4c2"/>
                                        <Setter Property="BorderBrush" Value="#f59e0b"/>
                                        <Setter Property="BorderThickness" Value="4,0,0,0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="" Binding="{Binding dirty_mark}" Width="28" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#d97706"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="日付" Binding="{Binding date}" Width="100"/>
                            <DataGridTextColumn Header="案件名称" Binding="{Binding project_name}" Width="160"/>
                            <DataGridTextColumn Header="工程" Binding="{Binding process_name}" Width="90"/>
                            <DataGridTextColumn Header="タスクグループ" Binding="{Binding task_group_name}" Width="110"/>
                            <DataGridTextColumn Header="タスク" Binding="{Binding task_name}" Width="110"/>
                            <DataGridTextColumn Header="カテゴリ" Binding="{Binding category_name}" Width="90"/>
                            <DataGridTextColumn Header="工数" Binding="{Binding hours, StringFormat=N1}" Width="60"/>
                            <DataGridTextColumn Header="コメント" Binding="{Binding comment}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- 右: 入力フォーム -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock x:Name="FormHeader" Text="✏ 新規エントリ" Style="{StaticResource SectionTitle}" DockPanel.Dock="Top"/>

                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="ClearBtn" Content="✕ クリア"/>
                        <Button x:Name="UpdateBtn" Content="✓ 更新" Style="{StaticResource Warning}" Visibility="Collapsed" MinWidth="100"/>
                        <Button x:Name="AddBtn" Content="＋ 追加" Style="{StaticResource Secondary}" MinWidth="100"/>
                    </StackPanel>

                    <StackPanel>
                        <Label Content="日付  (バックデートOK)" Margin="0,2,0,0"/>
                        <StackPanel Orientation="Horizontal">
                            <DatePicker x:Name="EntryDate" Width="180"/>
                            <Button x:Name="TodayBtn" Content="📅 今日" MinWidth="68" Margin="4,1,0,1" MinHeight="26" Padding="6,2"/>
                            <Button x:Name="YesterdayBtn" Content="↩ 昨日" MinWidth="68" Margin="2,1,0,1" MinHeight="26" Padding="6,2"/>
                        </StackPanel>

                        <CheckBox x:Name="IsLeaveChk" Content="🏖 休暇 (プロジェクト/工程/タスク不要)"
                                  Margin="0,8,0,2" FontWeight="SemiBold"
                                  ToolTip="ON にすると有給休暇/半休/特別休暇 等を記録できます。プロジェクト等の選択は不要になります"/>

                        <Label Content="プロジェクト (ユニット)" Margin="0,4,0,0"/>
                        <ComboBox x:Name="ProjectCombo" DisplayMemberPath="display" SelectedValuePath="unit_code"
                                  IsEditable="True" IsTextSearchEnabled="True" StaysOpenOnEdit="True"
                                  TextSearch.TextPath="display"/>

                        <Label Content="工程" Margin="0,3,0,0"/>
                        <ComboBox x:Name="ProcessCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                        <Label Content="タスクグループ" Margin="0,3,0,0"/>
                        <ComboBox x:Name="TaskGroupCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                        <Label Content="タスク" Margin="0,3,0,0"/>
                        <ComboBox x:Name="TaskCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                        <Border x:Name="TaskDescBorder" Margin="0,4,0,0" Padding="8,6" CornerRadius="4"
                                Background="#fffbeb" BorderBrush="#fcd34d" BorderThickness="1"
                                Visibility="Collapsed">
                            <TextBlock x:Name="TaskDescText" TextWrapping="Wrap" FontSize="12" Foreground="#92400e"/>
                        </Border>

                        <Label Content="作業カテゴリ" Margin="0,4,0,0"/>
                        <ComboBox x:Name="CategoryCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                        <Label Content="工数 (時間)" Margin="0,4,0,0"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="HoursBox" Text="1.0" FontSize="15" FontWeight="Bold" Width="80"/>
                            <Button x:Name="H025" Content="0.25" Style="{StaticResource QuickHour}" Tag="0.25" MinHeight="26" Margin="4,1,2,1"/>
                            <Button x:Name="H05"  Content="0.5"  Style="{StaticResource QuickHour}" Tag="0.5"  MinHeight="26" Margin="2,1"/>
                            <Button x:Name="H1"   Content="1"    Style="{StaticResource QuickHour}" Tag="1"    MinHeight="26" Margin="2,1"/>
                            <Button x:Name="H2"   Content="2"    Style="{StaticResource QuickHour}" Tag="2"    MinHeight="26" Margin="2,1"/>
                            <Button x:Name="H4"   Content="4"    Style="{StaticResource QuickHour}" Tag="4"    MinHeight="26" Margin="2,1"/>
                            <Button x:Name="H8"   Content="8"    Style="{StaticResource QuickHour}" Tag="8"    MinHeight="26" Margin="2,1"/>
                        </StackPanel>

                        <Label Content="コメント (任意)" Margin="0,4,0,0"/>
                        <TextBox x:Name="CommentBox" Height="50" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
