<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WorkTime Tracker"
    Height="780" Width="1280"
    WindowStartupLocation="CenterScreen"
    Background="#1e1e2e"
    FontFamily="Yu Gothic UI"
    FontSize="13">
    <Window.Resources>
        <!-- カラーパレット (Catppuccin Mocha 風) -->
        <SolidColorBrush x:Key="Bg"        Color="#1e1e2e"/>
        <SolidColorBrush x:Key="Surface"   Color="#181825"/>
        <SolidColorBrush x:Key="Surface2"  Color="#313244"/>
        <SolidColorBrush x:Key="Border"    Color="#45475a"/>
        <SolidColorBrush x:Key="Text"      Color="#cdd6f4"/>
        <SolidColorBrush x:Key="TextMuted" Color="#a6adc8"/>
        <SolidColorBrush x:Key="Green"     Color="#a6e3a1"/>
        <SolidColorBrush x:Key="Blue"      Color="#89b4fa"/>
        <SolidColorBrush x:Key="Peach"     Color="#fab387"/>
        <SolidColorBrush x:Key="Red"       Color="#f38ba8"/>
        <SolidColorBrush x:Key="Yellow"    Color="#f9e2af"/>
        <SolidColorBrush x:Key="Mauve"     Color="#cba6f7"/>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#11111b"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Text}"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>

        <!-- 標準ボタン -->
        <Style TargetType="Button">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Background" Value="{StaticResource Surface2}"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#45475a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#585b70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- アクセント (緑/青/赤) ボタン -->
        <Style x:Key="AccentGreen" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Green}"/>
            <Setter Property="Foreground" Value="#11111b"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#94d68f"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#7fc983"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentBlue" TargetType="Button" BasedOn="{StaticResource AccentGreen}">
            <Setter Property="Background" Value="{StaticResource Blue}"/>
        </Style>
        <Style x:Key="AccentRed" TargetType="Button" BasedOn="{StaticResource AccentGreen}">
            <Setter Property="Background" Value="{StaticResource Red}"/>
        </Style>
        <Style x:Key="AccentYellow" TargetType="Button" BasedOn="{StaticResource AccentGreen}">
            <Setter Property="Background" Value="{StaticResource Yellow}"/>
        </Style>

        <!-- クイック数値ボタン -->
        <Style x:Key="QuickHour" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="38"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- カードコンテナ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- セクションタイトル -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Green}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ===== ヘッダ ===== -->
        <Border DockPanel.Dock="Top" Background="#11111b" Padding="16,12">
            <DockPanel>
                <!-- 右: 設定/管理 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="AdminBtn" Content="🛠 管理者モード" Visibility="Collapsed"/>
                    <Button x:Name="SettingsBtn" Content="⚙ 設定"/>
                </StackPanel>
                <!-- 中: 表示年月 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="📅 表示" Foreground="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                    <ComboBox x:Name="YearCombo" Width="80"/>
                    <TextBlock Text="/" Margin="4,0" Foreground="{StaticResource TextMuted}"/>
                    <ComboBox x:Name="MonthCombo" Width="60"/>
                    <Button x:Name="ReloadBtn" Content="再読込" Margin="8,0,0,0"/>
                </StackPanel>
                <!-- 左: 作業者表示 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource Surface2}" CornerRadius="20" Padding="14,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock x:Name="CurrentMemberText" Text="" FontWeight="Bold" FontSize="14" Foreground="{StaticResource Text}"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="StatusText" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource Yellow}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== フッタ ===== -->
        <Border DockPanel.Dock="Bottom" Background="#11111b" Padding="16,12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" x:Name="ModeText" Foreground="{StaticResource TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="{StaticResource Surface2}" CornerRadius="6" Padding="12,6" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⏱ 月合計" Foreground="{StaticResource TextMuted}" Margin="0,0,8,0"/>
                            <TextBlock x:Name="HoursTotalText" Text="0.0 h" FontWeight="Bold" FontSize="16" Foreground="{StaticResource Yellow}"/>
                        </StackPanel>
                    </Border>
                    <Button x:Name="SaveBtn" Content="💾 保存 (GitLab へ送信)" Style="{StaticResource AccentGreen}" MinWidth="200"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== 本体 ===== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左: 入力フォーム -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock x:Name="FormHeader" Text="✏ 新規エントリ" Style="{StaticResource SectionTitle}" DockPanel.Dock="Top"/>

                    <!-- ボタン行 -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                        <Button x:Name="ClearBtn" Content="✖ クリア"/>
                        <Button x:Name="UpdateBtn" Content="✓ 更新" Style="{StaticResource AccentYellow}" Visibility="Collapsed" MinWidth="100"/>
                        <Button x:Name="AddBtn" Content="＋ 追加" Style="{StaticResource AccentBlue}" MinWidth="100"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- 日付 -->
                            <Label Content="日付  (バックデートOK)"/>
                            <StackPanel Orientation="Horizontal">
                                <DatePicker x:Name="EntryDate" Width="200"/>
                                <Button x:Name="TodayBtn" Content="今日" MinWidth="60" Margin="6,2,0,2"/>
                                <Button x:Name="YesterdayBtn" Content="昨日" MinWidth="60" Margin="2,2,0,2"/>
                            </StackPanel>

                            <!-- 4段カスケード -->
                            <Label Content="プロジェクト" Margin="0,10,0,0"/>
                            <ComboBox x:Name="ProjectCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                            <Label Content="工程"/>
                            <ComboBox x:Name="ProcessCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                            <Label Content="タスクグループ"/>
                            <ComboBox x:Name="TaskGroupCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                            <Label Content="タスク"/>
                            <ComboBox x:Name="TaskCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                            <!-- カテゴリ -->
                            <Label Content="作業カテゴリ" Margin="0,10,0,0"/>
                            <ComboBox x:Name="CategoryCombo" DisplayMemberPath="name" SelectedValuePath="code"/>

                            <!-- 工数 -->
                            <Label Content="工数 (時間)" Margin="0,10,0,0"/>
                            <TextBox x:Name="HoursBox" Text="1.0" FontSize="16" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button x:Name="H025" Content="0.25" Style="{StaticResource QuickHour}" Tag="0.25"/>
                                <Button x:Name="H05"  Content="0.5"  Style="{StaticResource QuickHour}" Tag="0.5"/>
                                <Button x:Name="H1"   Content="1"    Style="{StaticResource QuickHour}" Tag="1"/>
                                <Button x:Name="H2"   Content="2"    Style="{StaticResource QuickHour}" Tag="2"/>
                                <Button x:Name="H4"   Content="4"    Style="{StaticResource QuickHour}" Tag="4"/>
                                <Button x:Name="H8"   Content="8"    Style="{StaticResource QuickHour}" Tag="8"/>
                            </StackPanel>

                            <!-- コメント -->
                            <Label Content="コメント (任意)" Margin="0,10,0,0"/>
                            <TextBox x:Name="CommentBox" Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- 右: 当月一覧 -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock x:Name="ListTitle" Text="📋 当月エントリ一覧" Style="{StaticResource SectionTitle}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="DuplicateBtn" Content="⎘ 行を複製"/>
                            <Button x:Name="EditRowBtn" Content="✎ 編集"/>
                            <Button x:Name="DeleteRowBtn" Content="🗑 削除" Style="{StaticResource AccentRed}"/>
                        </StackPanel>
                    </DockPanel>

                    <DataGrid x:Name="EntriesGrid"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              Background="#11111b"
                              Foreground="{StaticResource Text}"
                              RowBackground="#11111b"
                              AlternatingRowBackground="#181825"
                              GridLinesVisibility="None"
                              BorderBrush="{StaticResource Border}"
                              BorderThickness="1"
                              FontSize="13"
                              RowHeight="32"
                              ColumnHeaderHeight="36">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource Surface2}"/>
                                <Setter Property="Foreground" Value="{StaticResource Mauve}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,4"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#45475a"/>
                                        <Setter Property="Foreground" Value="{StaticResource Text}"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="日付" Binding="{Binding date}" Width="100"/>
                            <DataGridTextColumn Header="プロジェクト" Binding="{Binding project_code}" Width="110"/>
                            <DataGridTextColumn Header="工程" Binding="{Binding process_code}" Width="80"/>
                            <DataGridTextColumn Header="ﾀｽｸｸﾞﾙｰﾌﾟ" Binding="{Binding task_group_code}" Width="100"/>
                            <DataGridTextColumn Header="タスク" Binding="{Binding task_code}" Width="100"/>
                            <DataGridTextColumn Header="カテゴリ" Binding="{Binding category}" Width="100"/>
                            <DataGridTextColumn Header="工数" Binding="{Binding hours, StringFormat=N1}" Width="70"/>
                            <DataGridTextColumn Header="コメント" Binding="{Binding comment}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
