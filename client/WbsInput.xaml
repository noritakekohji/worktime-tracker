<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WBS 実績入力 - WorkTime Tracker"
    Height="720" Width="1280"
    MinHeight="480" MinWidth="900"
    WindowStartupLocation="CenterScreen"
    Background="#f6faf8"
    FontFamily="Meiryo UI, Yu Gothic UI, Segoe UI"
    FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="Emerald"  Color="#10b981"/>
        <SolidColorBrush x:Key="EmeraldD" Color="#059669"/>
        <SolidColorBrush x:Key="Surface"  Color="#ffffff"/>
        <SolidColorBrush x:Key="Border"   Color="#cdebd6"/>
        <SolidColorBrush x:Key="Text"     Color="#1f2937"/>
        <SolidColorBrush x:Key="Muted"    Color="#6b7280"/>
        <SolidColorBrush x:Key="Weekend"  Color="#b45309"/>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0,0,4,0"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Background" Value="#ecfdf5"/>
            <Setter Property="Foreground" Value="{StaticResource EmeraldD}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#d1fae5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Primary" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Emerald}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="{StaticResource Emerald}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource EmeraldD}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Padding" Value="2,2"/>
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ===== ヘッダバー ===== -->
        <Border DockPanel.Dock="Top" Background="{StaticResource EmeraldD}" Padding="14,10">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="📊 WBS 実績入力" FontSize="17" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center" Margin="0,0,18,0"/>
                <Label Content="プロジェクト:"/>
                <!-- A3: IsEditable で型入れ検索可能 (TextSearch でマッチした項目へジャンプ) -->
                <ComboBox x:Name="ProjectCombo" Width="280" Margin="0,0,12,0"
                          DisplayMemberPath="display" Background="White"
                          IsEditable="True" IsTextSearchEnabled="True"
                          StaysOpenOnEdit="True"
                          TextSearch.TextPath="display"/>
                <Label Content="年:"/>
                <ComboBox x:Name="YearCombo" Width="68" Margin="0,0,4,0" Background="White"/>
                <Label Content="月:"/>
                <ComboBox x:Name="MonthCombo" Width="52" Margin="0,0,12,0" Background="White"/>
                <Label Content="担当者:"/>
                <ComboBox x:Name="MemberCombo" Width="160" Margin="0,0,10,0"
                          DisplayMemberPath="display" Background="White"/>
                <Button x:Name="LoadBtn"  Content="📋 読込" Style="{StaticResource Primary}" Margin="0,0,0,0"/>
                <Button x:Name="AdminBtn" Content="🔧 管理者" Margin="6,0,0,0" Visibility="Collapsed" ToolTip="マスタ編集 / 他者データ編集"/>
            </WrapPanel>
        </Border>

        <!-- ===== フッタ (ステータス + 保存) ===== -->
        <Border DockPanel.Dock="Bottom" Background="#f0fdf4"
                BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="12,7">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="SaveBtn" Content="💾 保存" Style="{StaticResource Primary}" MinWidth="100"/>
                    <Button x:Name="PushBtn" Content="📤 送信" Style="{StaticResource Primary}"
                            MinWidth="100" Margin="6,3,3,3"
                            ToolTip="ローカル保存 + Gitlabへ送信 (gitlabモードのみ有効)"/>
                </StackPanel>
                <TextBlock x:Name="StatusText"
                           Text="プロジェクトと月を選択して「読込」を押してください"
                           VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
            </DockPanel>
        </Border>

        <!-- ===== メイン: ツリー + グリッド ===== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210" MinWidth="140" MaxWidth="380"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左: WBS 階層ツリー -->
            <Border Grid.Column="0" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                <DockPanel Margin="8">
                    <TextBlock DockPanel.Dock="Top" Text="🗂 WBS 階層" FontWeight="Bold"
                               Foreground="{StaticResource EmeraldD}" Margin="0,0,0,8"/>
                    <Button DockPanel.Dock="Bottom" x:Name="AddRowBtn"
                            Content="＋ 選択タスクに行を追加" IsEnabled="False" Margin="0,8,0,0"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <TreeView x:Name="WbsTree" BorderThickness="0" Background="Transparent"
                                  ItemContainerStyle="{StaticResource TreeItemStyle}"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- スプリッター -->
            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource Border}" Cursor="SizeWE"/>

            <!-- 右: DataGrid -->
            <Border Grid.Column="2" Background="{StaticResource Surface}">
                <DockPanel Margin="4">
                    <TextBlock DockPanel.Dock="Top" x:Name="GridTitle"
                               Text="プロジェクトを選択して「読込」を押してください"
                               FontWeight="Bold" Foreground="{StaticResource EmeraldD}"
                               Margin="6,6,6,8"/>
                    <DataGrid x:Name="WbsGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              CanUserResizeRows="False" CanUserReorderColumns="False"
                              HeadersVisibility="Column"
                              Background="White" RowBackground="White"
                              AlternatingRowBackground="#f0fdf4"
                              GridLinesVisibility="All" HorizontalGridLinesBrush="#d1fae5" VerticalGridLinesBrush="#d1fae5"
                              BorderBrush="{StaticResource Border}" BorderThickness="1"
                              RowHeight="28" ColumnHeaderHeight="34" FontSize="12"
                              SelectionMode="Single" SelectionUnit="Cell"
                              EnableColumnVirtualization="True"
                              EnableRowVirtualization="True"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridCell">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="4,2"/>
                            </Style>
                        </DataGrid.Resources>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
